# Kitchen Display — local OAuth client configuration.
# Copy this file to ".env" and fill in the values you get from Azure / Google.
# ".env" is git-ignored. You can also enter these in the in-app Settings screen.

# --- Microsoft 365 (Azure App Registration) ---
# Application (client) ID from Azure Portal > App registrations.
# Account type was registered as "any org + personal", so we use the "common" authority.
MS_CLIENT_ID=YOUR_AZURE_APPLICATION_CLIENT_ID
MS_AUTHORITY=https://login.microsoftonline.com/common

# --- Google (Google Cloud OAuth client, type "Desktop app") ---
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# Desktop-app clients may also issue a client secret; paste it if present.
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# --- Camera ---
# Optional default RTSP URL; normally set this in Settings instead of here.
# RTSP_URL=rtsp://user:pass@192.168.1.50:554/stream1
